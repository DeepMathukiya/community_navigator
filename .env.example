# MongoDB Configuration
# For local MongoDB: mongodb://localhost:27017
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=pdf_extraction_db
MONGODB_COLLECTION_NAME=extracted_data

# NVIDIA Nemotron Configuration
# Get your API key from: https://developer.nvidia.com/ai-api
# This uses NVIDIA's Nemotron-3 Super 120B model with extended thinking
NVIDIA_API_KEY=your_nvidia_api_key_here

# PDF Storage Configuration
# Path where uploaded PDFs will be stored locally
PDF_STORAGE_PATH=./uploaded_pdfs

# Model Configuration
# Using NVIDIA Nemotron-3 Super 120B with advanced reasoning capabilities
NVIDIA_MODEL=nvidia/nemotron-3-super-120b-a12b
